{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "node16",
    "lib": ["ES2020", "DOM"],
    "outDir": "dist",
    "strict": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node", "vscode"],
    "baseUrl": ".",
    "paths": {
      "@jarvis/core": ["packages/core/src/index.ts"],
      "@jarvis/core/vscode": ["packages/core/src/vscode.ts"]
    }
  },
  "include": [
    "src/extension.ts",
    "packages/core/src/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "src/frontend/**"]
}
