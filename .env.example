# Exemple de variables d'environnement pour Jarvis Agent

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Mistral API
MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai

# Autres providers ou services externes
# OLLAMA ne nécessite généralement pas de clé pour un service local,
# mais vous pouvez définir une URL si nécessaire.
OLLAMA_BASE_URL=http://localhost:11434

# Optionnel : configuration du workspace / services locaux
JARVIS_LOG_LEVEL=info
