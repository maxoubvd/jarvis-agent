{
  "name": "jarvis-agent",
  "displayName": "Jarvis Code Agent",
  "publisher": "MaximeBendavid",
  "description": "Agentic VS Code extension - Your autonomous software engineer. Multi-provider agentic chat (local or cloud), inline editing (Cmd+K), Auto-TDD, local RAG, specialized agents, Git checkpoints.",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/extension.js",
  "icon": "media/jarvis-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxoubvd/extension-VS-code.git"
  },
  "bugs": {
    "url": "https://github.com/maxoubvd/extension-VS-code/issues"
  },
  "homepage": "https://github.com/maxoubvd/extension-VS-code#readme",
  "qna": "https://github.com/maxoubvd/extension-VS-code/issues",
  "keywords": [
    "ai",
    "agent",
    "chat",
    "coding-assistant",
    "ollama",
    "openrouter",
    "llm",
    "autocomplete",
    "rag",
    "mcp"
  ],
  "galleryBanner": {
    "color": "#1E1B2E",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "license": "MIT",
  "pricing": "Free",
  "markdown": "github",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "Jarvis Agent's agent tools (terminal execution, file read/write) require a trusted workspace to run."
    }
  },
  "scripts": {
    "build:extension": "tsc -p tsconfig.json --noEmit && node build-extension.mjs",
    "build:webview": "vite build",
    "build": "npm run build:extension && npm run build:webview",
    "watch:webview": "vite build --watch",
    "package": "npm run build && node copy-static.js && node strip-vendor-assets.mjs && vsce package",
    "publish": "vsce publish",
    "postinstall": "patch-package",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts,.svelte"
  },
  "dependencies": {
    "@xenova/transformers": "^2.0.1",
    "web-tree-sitter": "^0.20.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/svelte": "^5.4.2",
    "@types/marked": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/prismjs": "^1.26.6",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vscode/vsce": "^3.9.2",
    "autoprefixer": "^10.5.2",
    "esbuild": "^0.25.12",
    "eslint": "^8.0.0",
    "eslint-plugin-svelte": "^2.46.1",
    "happy-dom": "^20.10.6",
    "jsdom": "^27.0.1",
    "marked": "^12.0.0",
    "patch-package": "^8.0.1",
    "postcss": "^8.0.0",
    "postcss-load-config": "^5.1.0",
    "prettier": "^3.0.0",
    "prismjs": "^1.29.0",
    "svelte": "^5.56.4",
    "svelte-eslint-parser": "^0.43.0",
    "svelte-preprocess": "^5.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.4.3",
    "vitest": "^4.1.9"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "jarvis-sidebar",
          "title": "Jarvis Agent",
          "icon": "media/jarvis.png"
        }
      ]
    },
    "views": {
      "jarvis-sidebar": [
        {
          "type": "webview",
          "id": "jarvis.sidebarView",
          "name": "Jarvis Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "jarvis.startChat",
        "title": "Jarvis: Start Chat"
      },
      {
        "command": "jarvis.rollback",
        "title": "Jarvis: Rollback to Checkpoint"
      },
      {
        "command": "jarvis.listCheckpoints",
        "title": "Jarvis: List Checkpoints"
      },
      {
        "command": "jarvis.exportAnalytics",
        "title": "Jarvis: Export Analytics"
      },
      {
        "command": "jarvis.generateJarvisignore",
        "title": "Jarvis: Generate .jarvisignore"
      },
      {
        "command": "jarvis.addToJarvisignore",
        "title": "Jarvis: Add to .jarvisignore"
      },
      {
        "command": "jarvis.removeFromJarvisignore",
        "title": "Jarvis: Remove from .jarvisignore"
      },
      {
        "command": "jarvis.indexWorkspace",
        "title": "Jarvis: Index Workspace (RAG)"
      },
      {
        "command": "jarvis.acceptAll",
        "title": "Jarvis: Accept All AI Changes"
      },
      {
        "command": "jarvis.rejectAll",
        "title": "Jarvis: Reject All AI Changes"
      },
      {
        "command": "jarvis.inlineEdit",
        "title": "Jarvis: Inline Edit (Cmd+K)"
      },
      {
        "command": "jarvis.init",
        "title": "Jarvis: Initialize Project (generate JARVIS.md)"
      }
    ],
    "keybindings": [
      {
        "command": "jarvis.inlineEdit",
        "key": "ctrl+k ctrl+k",
        "mac": "cmd+k cmd+k",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "jarvis.addToJarvisignore",
          "group": "7_modification"
        }
      ]
    },
    "configuration": {
      "title": "Jarvis Agent",
      "properties": {
        "jarvis.models.default": {
          "type": "string",
          "default": "",
          "description": "Legacy — the default model is managed in the Settings tab (~/.jarvis/config.json)"
        },
        "jarvis.hitl.mode": {
          "type": "string",
          "default": "moderate",
          "enum": [
            "strict",
            "moderate",
            "free"
          ],
          "description": "Human-in-the-Loop validation mode"
        },
        "jarvis.autoOpen.mode": {
          "type": "string",
          "default": "always",
          "enum": [
            "always",
            "never",
            "strict-hitl-only"
          ],
          "description": "Automatically open the file edited by the agent (preview tab)"
        },
        "jarvis.autocomplete.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Inline autocomplete (Tab / ghost text) — calls a model on every typing pause"
        },
        "jarvis.agent.maxIterations": {
          "type": "number",
          "default": 100,
          "description": "Maximum number of iterations for the agent loop (e.g. tool calls, error fixes) before asking for permission to continue."
        },
        "jarvis.tdd.maxAttempts": {
          "type": "number",
          "default": 5,
          "description": "Maximum number of attempts for the Auto-TDD loop"
        },
        "jarvis.tdd.testCommand": {
          "type": "string",
          "default": "npm test",
          "description": "Test command used by the Auto-TDD loop"
        },
        "jarvis.terminal.timeout": {
          "type": "number",
          "default": 30000,
          "description": "Terminal command timeout (ms)"
        }
      }
    }
  }
}
