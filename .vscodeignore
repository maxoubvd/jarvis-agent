media/jarvis-icon-source.svg
# Unreferenced leftovers from the SVG->PNG icon migration (icon fields in package.json
# now point to .png) -- excluded so no .svg ships at all, removing any ambiguity around
# vsce's "will not publish extensions that contain user-provided SVG images" check.
media/jarvis-icon.svg
media/jarvis.svg
**/.DS_Store

# Extension host is bundled by esbuild (build-extension.mjs) into a single
# dist/extension.js — everything pure-JS gets inlined there. Only packages with
# native binaries or runtime-relative asset loading (that can't be bundled) need
# to ship as real node_modules files, so allowlist just those.
# IMPORTANT: patterns must use `/**` — a single `*` does not cross directory
# separators, so `node_modules/*` matches nothing nested and ships the whole tree
# (incl. onnxruntime-node's unsigned native .dll/.node binaries, which the
# Marketplace upload scanner flags as "suspicious content").
node_modules/**
!node_modules/@xenova/**
!node_modules/onnxruntime-web/**
!node_modules/onnxruntime-common/**
!node_modules/web-tree-sitter/**
# onnxruntime-node is never loaded at runtime: @xenova/transformers is patched
# (patches/@xenova+transformers+2.0.1.patch) to always use the WASM backend, whose
# Node entry (onnxruntime-web/dist/ort.node.min.mjs) only imports onnxruntime-common.
# NOTE: vsce does not apply per-subpath excludes for packages it has already decided
# to include in full -- .cache/ and @xenova/transformers/dist/ are instead physically
# removed by strip-vendor-assets.mjs, run as part of the `package` script.

# README-only demo video: the Marketplace strips <video> tags anyway, no reason
# to ship 10+ MB in the vsix. (media/Jarvis Avatar Animation.mp4 stays: used by the webview.)
media/user_guide_jarvis.mp4
